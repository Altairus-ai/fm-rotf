    "details": { "biography": { "value": "<p>A living demiplane is a demiplane spell that has become vaguely self-aware. It is a shadowy rectangle, 5 feet wide and 10 feet high, which creeps along flat, solid surfaces and groans softly when it moves.</p>" }, "alignment": "unaligned", "race": "", "type": { "value": "construct", "subtype": "", "swarm": "", "custom": "" }, "environment": "", "cr": 0, "spellLevel": 0, "source": { "book": "Icewind Dale: Rime of the Frostmaiden", "page": "300" } },
